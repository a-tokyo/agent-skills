TARGET_ID=fixture-mssql
DIALECT=mssql
# Throwaway, localhost-only fixture credential. Define it once (overridable) and interpolate it into the DSN
# so it matches docker-compose.yml's ${BENCH_DB_PASSWORD:-...} and isn't duplicated as a second literal.
BENCH_DB_PASSWORD="${BENCH_DB_PASSWORD:-Bench_Pass123!}"
DATABASE_URL="sqlserver://localhost:1434;database=bench;user=sa;password=${BENCH_DB_PASSWORD};encrypt=false;trustServerCertificate=true"
SCHEMAS=dbo
